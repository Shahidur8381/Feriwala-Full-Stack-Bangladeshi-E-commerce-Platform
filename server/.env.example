# Server Environment Variables
# Copy this file to .env and fill in values

# Server
PORT=5000
NODE_ENV=development

# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://user:password@host:port/database"

# Supabase
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"

# Authentication
JWT_SECRET="your-strong-jwt-secret-here"

# SSLCommerz Payment Gateway
# Sandbox: store_id=testbox, store_passwd=qwerty
# Production: Get from https://developer.sslcommerz.com
SSLCZ_STORE_ID="testbox"
SSLCZ_STORE_PASSWORD="qwerty"
SSLCZ_IS_LIVE=false

# Frontend URLs (for SSLCommerz redirects)
CLIENT_URL="http://localhost:3000"

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173,http://localhost:4000"
